# Airtable — personal access token with scopes data.records:read, data.records:write
# on the "BFF FR AI Gamification" base.
# Create at: https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# Base ID: starts with "app…", copy from the Airtable base URL
AIRTABLE_BASE_ID=

# Shared passcode for /admin. Keep in 1Password. Anything 12+ chars is fine.
ADMIN_PASSCODE=

# Canonical public URL. Locally: http://localhost:3000
# In Railway: the *.up.railway.app URL (set after first deploy).
NEXT_PUBLIC_APP_URL=http://localhost:3000
